const express = require('express');
const cors = require('cors');
const http = require('http');
const { Server } = require('socket.io');

const app = express();

// 1. Configuración de CORS para las rutas de la API (Express)
const corsOptions = {
  origin: 'https://aprende-python-theta.vercel.app', // Tu dominio exacto de Vercel (sin / al final)
  methods: ['GET', 'POST', 'PUT', 'DELETE', 'OPTIONS'],
  credentials: true // Necesario si envías cookies, tokens de autorización o sesiones
};

app.use(cors(corsOptions));
app.use(express.json()); // Para poder leer el body de las peticiones

// ... aquí van tus rutas (ej. app.use('/api', apiRoutes)) ...

// 2. Crear el servidor HTTP usando la app de Express
const server = http.createServer(app);

// 3. Configuración de CORS para WebSockets (Socket.io)
const io = new Server(server, {
  cors: {
    origin: 'https://aprende-python-theta.vercel.app',
    methods: ['GET', 'POST'],
    credentials: true
  }
});

// Lógica de tus sockets
io.on('connection', (socket) => {
  console.log('Un usuario se ha conectado');
  // ... tu código de socket.io ...
});

// 4. Escuchar en el puerto (Asegúrate de usar 'server.listen' y no 'app.listen')
const PORT = process.env.PORT || 3000;
server.listen(PORT, () => {
  console.log(`Servidor corriendo en el puerto ${PORT}`);
});